# Jarvis Prime Bridge Service
PORT=3100
CLAUDE_PATH=/home/tripp/.local/bin/claude
CLAUDE_MODEL=sonnet
CLAUDE_TIMEOUT_MS=120000

# Telegram — jarvis-prime polls this bot directly
TELEGRAM_BOT_TOKEN=
TRIPP_CHAT_ID=8048875001

# OpenClaw delivery (fallback/legacy)
# Required (non-empty) when CORPUS_CALLOSUM_ENABLED=true.
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=

# Corpus callosum — dual-brain (left=Claude, right=OpenClaw chat model)
# Set CORPUS_CALLOSUM_ENABLED=false to disable dual-brain and fall back to
# single-brain Claude (kill switch). Accepts true/false/1/0/yes/no/on/off.
CORPUS_CALLOSUM_ENABLED=true
# Model identifier passed to the OpenClaw gateway for the right hemisphere.
# Must be an OpenClaw path-style ID (see agents.defaults.model in openclaw.json).
# OpenClaw's /v1/chat/completions endpoint must be enabled:
#   jq '.gateway.http.endpoints.chatCompletions.enabled = true' openclaw.json
OPENCLAW_CHAT_MODEL_RIGHT=openai-codex/gpt-5.4
# Per-hemisphere HTTP/CLI timeout, in milliseconds.
CORPUS_CALLOSUM_TIMEOUT_MS=240000
# Clinical override: when true, all natural-language messages route to
# single-brain Claude (PHI belt-and-suspenders; right hemisphere never called).
CORPUS_CLINICAL_OVERRIDE=false

# Wave 6 — Telegram evolving-message UX. When true, the bridge renders a
# single evolving bubble per message (Thinking → Drafting → Revising →
# Integrating → final) and emits a typing heartbeat. When false, falls
# back to the pre-Wave-6 two-message path (ack + final).
JARVIS_EVOLVING_MESSAGE_ENABLED=true

# Wave 7 — right hemisphere via persistent OpenClaw agent. When true, the
# right hemisphere is served by the `right-brain` OpenClaw agent (session
# id derived deterministically from chatId → cross-turn memory) instead of
# a stateless `/v1/chat/completions` call. Requires the agent and its
# workspace allowlist to be set up via scripts/setup-right-brain-agent.sh.
RIGHT_BRAIN_AGENT_ENABLED=false
# When true AND the agent throws a transport error (exec failure, malformed
# JSON, embedded fallback), the bridge retries once on the legacy
# chat-completions client. Model errors (non-ok status from the agent) never
# trigger fallback — they propagate so the upstream defect stays visible.
RIGHT_BRAIN_AGENT_FALLBACK=true

# Wave 8 — Brain-directed skill router. When true, Claude (left) plans each
# natural-language turn and dispatches skills (jarvis-dev-methodology or
# research-methodology) to the right hemisphere via in-bridge shim. When
# false, orchestrator runs the Wave 7 drafting-only flow byte-for-byte.
# Ships dark (false). Flip to true only after Wave 8 E2E + live smoke pass.
JARVIS_ROUTER_ENABLED=false

# Paths
WORKSPACE_DIR=/home/tripp/.openclaw/workspace
DELIVERY_QUEUE_DIR=/home/tripp/.openclaw/delivery-queue
